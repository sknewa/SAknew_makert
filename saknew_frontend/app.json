{
  "expo": {
    "name": "SAMakert",
    "slug": "samakert",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/weblog.jpg",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "jsEngine": "hermes",
    "sdkVersion": "54.0.0",
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location."
        }
      ]
    ],
    "splash": {
      "image": "./assets/weblog.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.saknew.market",
      "buildNumber": "1.0.0",
      "requireFullScreen": false,
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs camera access to take product photos",
        "NSLocationWhenInUseUsageDescription": "This app needs location access to show nearby products and shops",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs location access to show nearby products and shops",
        "NSPhotoLibraryUsageDescription": "This app needs photo library access to select product images",
        "CFBundleDisplayName": "SAMakert",
        "CFBundleName": "SAMakert",
        "CFBundleShortVersionString": "1.0.0",
        "CFBundleVersion": "1.0.0",
        "UILaunchStoryboardName": "SplashScreen",
        "UIRequiresFullScreen": false,
        "UIViewControllerBasedStatusBarAppearance": true
      },
      "associatedDomains": [],
      "entitlements": {},
      "scheme": "samakert"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/weblog.jpg",
        "backgroundColor": "#667eea"
      },
      "package": "com.saknew.market",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/weblog.jpg"
    },
    "extra": {
      "SERVER_IP": "saknew-market-backend-f8738ecec7fa.herokuapp.com",
      "SERVER_PORT": "443",
      "API_BASE_URL": "https://saknew-market-backend-f8738ecec7fa.herokuapp.com/",
      "IMAGE_BASE_URL": "https://saknew-market-backend-f8738ecec7fa.herokuapp.com",
      "AI_SERVICE_URL": "https://saknew-market-backend-f8738ecec7fa.herokuapp.com/api/ai",
      "DEBUG": "false",
      "APP_ENV": "production"
    }
  }
}
